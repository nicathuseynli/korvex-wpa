# ── Korvex backend (the .NET API shared with the Telegram bot) ────────────
# Public base URL of the Korvex .NET API. Same value the bot uses.
KORVEX_BACKEND_URL=https://api.media-flow-api.com

# Shared secret authenticating the web app to the backend (header X-Bot-Secret).
# MUST match Bot.SharedSecret in /opt/korvex/appsettings.Production.json
# and BACKEND_BOT_SECRET in /opt/korvex-bot/.env.
KORVEX_BOT_SECRET=replace-me

# ── Legacy (existing activation-key flow) ────────────────────────────────
KORVEX_API_BASE_URL=https://api.media-flow-api.com

# ── Email (Resend) ────────────────────────────────────────────────────────
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Must be a verified sender in Resend (set up SPF + DKIM for the domain).
EMAIL_FROM=Korvex VPN <noreply@media-flow-api.com>

# ── Plan prices (minor units — e.g. kopeks for RUB) ───────────────────────
# Keep in sync with /opt/korvex-bot/.env PRICE_* values so the web and bot
# sell the same product at the same price. Minor units = RUB × 100.
PLAN_CURRENCY=RUB
PLAN_PRICE_1_MONTH=19900
PLAN_PRICE_3_MONTHS=49900
PLAN_PRICE_6_MONTHS=89900
PLAN_PRICE_12_MONTHS=149900
PLAN_PRICE_FAMILY_1_MONTH=34900
PLAN_PRICE_FAMILY_3_MONTHS=89900

# ── Support ──────────────────────────────────────────────────────────────
SUPPORT_USERNAME=HelpKorvexVPN

# ── Test mode ─────────────────────────────────────────────────────────────
# When true: skips payment, provisions + emails immediately. Turn OFF before
# production traffic. When false, POST /api/web/checkout returns 501 until
# a payment provider is wired.
TEST_MODE=true

# ── Web-channel Postgres (orders + rate limits) ──────────────────────────
# DEDICATED database — do NOT reuse `korvex` or `korvex_bot`. Create it once:
#   sudo -u postgres psql -c "CREATE DATABASE korvex_web OWNER korvex;"
# Password-encode special chars: & -> %26, @ -> %40, # -> %23
WEB_DATABASE_URL=postgres://korvex:dostumIsmetSalamSene45%26890__%40@127.0.0.1:5432/korvex_web
